# Angetic Essence License Server — Production Environment
# Copy this to /opt/angetic-license/.env and fill in your values

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=licenses@angeticessence.com

STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
ADMIN_API_KEY=generate-a-random-64-char-hex-key-here

PORT=8080
SITE_URL=https://api.angeticessence.com
