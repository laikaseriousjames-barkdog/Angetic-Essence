# License Server Configuration
# Copy this file to .env and fill in your values

# SMTP — used to email license keys to customers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=licenses@angeticessence.com

# Stripe — webhook secret from Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Admin API key for /admin/* endpoints
ADMIN_API_KEY=generate-a-random-secure-key-here

# Server
PORT=8080
SITE_URL=https://angeticessence.com
